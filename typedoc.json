{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "./src/index.ts"
    ],
    "out": "./docs/api",
    "plugin": [
        "typedoc-plugin-markdown"
    ],
    "hidePageTitle": true,
    "hideBreadcrumbs": true,
    "hidePageHeader": true,
    "entryFileName": "index.md",
    "mergeReadme": true,
    "excludeGroups": true
}
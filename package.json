{
    "name": "discord-message-builder",
    "version": "1.0.0",
    "description": "Construct Discord messages using a builder pattern",
    "type": "commonjs",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsup src/index.ts --format cjs,esm --dts --splitting false",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src",
        "prepublishOnly": "npm run build",
        "docs:generate": "typedoc",
        "docs:start": "npm run docs:generate && cd docs && npm run start"
    },
    "keywords": [
        "discord",
        "discord api",
        "discordjs"
    ],
    "author": {
        "name": "dogicing",
        "url": "https://github.com/dogicing"
    },
    "license": "MIT",
    "dependencies": {
        "discord-api-types": "^0.38.48",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.4.1",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "rimraf": "^6.1.3",
        "tsup": "^8.5.1",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.12.0",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8"
    }
}